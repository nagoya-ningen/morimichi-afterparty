rules_version = '2';

/* 森道 After party — Firestore セキュリティルール（事後モデレーション制）

   方針：
   ・posts の read は「hidden=false かつ status=published」を公開する。
     運営は全件閲覧可。
   ・create はフィールドを厳密に検証する。すべての投稿は status='published'
     で即時公開（事後モデレーション）。画像つきも即時公開。
     不適切な投稿は通報経由で運営が hidden=true で即時非表示にする。
   ・createdAt はサーバー時刻と一致を強制（クライアントによる時刻偽装を阻止）。
   ・snsUrl は http(s) のみ許可（javascript: 等のXSS阻止）。
   ・imageUrl は Cloudinary のドメインのみ許可（任意URL注入の阻止）。
   ・非表示(hidden)・削除は運営のみ。
   ・運営判定は request.auth.token.email == 管理者メール。
   ・App Check を有効にすると、これに加えてBotの書き込みが弾かれる。

   ▼ セットアップ：adminEmail() を運営者の管理用メールアドレスに置き換える。 */

service cloud.firestore {
  match /databases/{database}/documents {

    /* ▼ ここを運営者の管理用メールアドレスに置き換える */
    function adminEmail() { return 'fff.yusei@gmail.com'; }
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == adminEmail();
    }

    match /posts/{postId} {
      /* 公開: hidden==false かつ status==published。運営は全件可。 */
      allow read: if isAdmin()
        || (resource.data.hidden == false
            && resource.data.status == 'published');

      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 200
        && request.resource.data.body is string
        && request.resource.data.body.size() >= 5
        && request.resource.data.body.size() <= 20000
        && request.resource.data.days is list
        && request.resource.data.days.size() >= 1
        && request.resource.data.days.size() <= 3
        && request.resource.data.days.hasOnly(['d1', 'd2', 'd3'])
        && request.resource.data.targetType in
             ['shop', 'area', 'artist', 'festival', 'staff']
        && request.resource.data.targetName is string
        && request.resource.data.targetName.size() <= 200
        && (request.resource.data.snsUrl == null
            || (request.resource.data.snsUrl is string
                && request.resource.data.snsUrl.size() <= 300
                && request.resource.data.snsUrl.matches('^https?://.*')))
        && request.resource.data.hidden == false
        && request.resource.data.reportCount == 0
        && request.resource.data.status == 'published'
        && request.resource.data.clientFlags is list
        && request.resource.data.clientFlags.size() <= 16
        && (
          /* テキストのみ */
          request.resource.data.imageUrl == null
          ||
          /* 画像つき：Cloudinary ドメインのみ許可 */
          (
            request.resource.data.imageUrl is string
            && request.resource.data.imageUrl.size() <= 600
            && request.resource.data.imageUrl.matches('^https://res\\.cloudinary\\.com/.*')
            && request.resource.data.imageConsent == true
          )
        );

      /* 非表示(hidden)のみ運営が変更可。他フィールドは変更不可。 */
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data)
             .affectedKeys().hasOnly(['hidden']);

      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      /* 通報は作成のみ。閲覧は運営のみ。 */
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.postId.size() <= 64
        && (request.resource.data.reason == null
            || (request.resource.data.reason is string
                && request.resource.data.reason.size() <= 500))
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    /* 上記以外のパスはすべて拒否 */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
