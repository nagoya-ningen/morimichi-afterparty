rules_version = '2';

/* 森道 After party — Firestore セキュリティルール（事後モデレーション制）

   方針：
   ・posts の read は「hidden=false かつ status=published」を公開する。
     運営は全件閲覧可。
   ・create はフィールドを厳密に検証する。すべての投稿は status='published'
     で即時公開（事後モデレーション）。画像つきも即時公開。
     不適切な投稿は通報経由で運営が hidden=true で即時非表示にする。
   ・createdAt はサーバー時刻と一致を強制（クライアントによる時刻偽装を阻止）。
   ・snsUrl は http(s) のみ許可（javascript: 等のXSS阻止）。
   ・imageUrl は Cloudinary のドメインのみ許可（任意URL注入の阻止）。
   ・非表示(hidden)・削除は運営のみ。
   ・運営判定は request.auth.token.email == 管理者メール。
   ・App Check を有効にすると、これに加えてBotの書き込みが弾かれる。

   ▼ セットアップ：adminEmail() を運営者の管理用メールアドレスに置き換える。 */

service cloud.firestore {
  match /databases/{database}/documents {

    /* ▼ ここを運営者の管理用メールアドレスに置き換える */
    function adminEmail() { return 'fff.yusei@gmail.com'; }
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == adminEmail();
    }

    match /posts/{postId} {
      /* 公開: hidden==false かつ status==published。運営は全件可。 */
      allow read: if isAdmin()
        || (resource.data.hidden == false
            && resource.data.status == 'published');

      allow create: if request.auth != null
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 200
        && request.resource.data.body is string
        && request.resource.data.body.size() >= 5
        && request.resource.data.body.size() <= 20000
        && request.resource.data.days is list
        && request.resource.data.days.size() >= 1
        && request.resource.data.days.size() <= 3
        && request.resource.data.days.hasOnly(['d1', 'd2', 'd3'])
        && request.resource.data.targetType in
             ['shop', 'area', 'artist', 'festival', 'staff']
        && request.resource.data.targetName is string
        && request.resource.data.targetName.size() <= 200
        /* targetId は文字列または null（pick:true 対象では文字列、free モード/festival/staff では null） */
        && (request.resource.data.targetId == null
            || (request.resource.data.targetId is string
                && request.resource.data.targetId.size() <= 64))
        && (request.resource.data.snsUrl == null
            || (request.resource.data.snsUrl is string
                && request.resource.data.snsUrl.size() <= 300
                && request.resource.data.snsUrl.matches('^https?://.*')))
        && request.resource.data.hidden == false
        && request.resource.data.reportCount == 0
        && request.resource.data.status == 'published'
        && request.resource.data.clientFlags is list
        && request.resource.data.clientFlags.size() <= 16
        /* 一般ユーザーは pinned / pinnedAt / reactions を設定不可 */
        && !(request.resource.data.keys()
              .hasAny(['pinned', 'pinnedAt', 'reactions']))
        && (
          /* テキストのみ */
          request.resource.data.imageUrl == null
          ||
          /* 画像つき：Cloudinary のうち自テナント（dsmrdy4kl）のドメインのみ許可。
             imagePublicId は文字列または null。 */
          (
            request.resource.data.imageUrl is string
            && request.resource.data.imageUrl.size() <= 600
            && request.resource.data.imageUrl.matches('^https://res\\.cloudinary\\.com/dsmrdy4kl/.*')
            && request.resource.data.imageConsent == true
            && (request.resource.data.imagePublicId == null
                || (request.resource.data.imagePublicId is string
                    && request.resource.data.imagePublicId.size() <= 200))
          )
        );

      /* 更新ルール：
         ・運営：hidden / pinned / pinnedAt の変更が可能（reactionsも上書き可）。
         ・一般ユーザー：reactions フィールド「のみ」の変更を許可。
           各キーは number で 0 以上、合計差分（4種すべての絶対差分の合計）が
           1 以下に限定する（連打や一括加算の不正な水増しを抑止）。
           ※ 厳密な重複防止は localStorage に依存。完全防止は Cloud Functions
              側で実装することを推奨（本Rulesは差分制約による簡易対策）。 */
      allow update: if (
        isAdmin()
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['hidden', 'pinned', 'pinnedAt', 'reactions'])
      ) || (
        request.auth != null
          && request.resource.data.diff(resource.data)
               .affectedKeys().hasOnly(['reactions'])
          && request.resource.data.reactions is map
          && reactionsValid(request.resource.data.reactions)
          && reactionsDiffOk(resource.data, request.resource.data)
      );

      allow delete: if isAdmin();
    }

    /* reactions オブジェクトのスキーマ検証：
       各キーは number で 0 以上。未定義キーは許可しない（4種のみ）。 */
    function reactionsValid(r) {
      return r.keys().hasOnly(['wakaru', 'sameba', 'ikitakatta', 'hozon'])
        && (!('wakaru' in r)     || (r.wakaru     is int && r.wakaru     >= 0))
        && (!('sameba' in r)     || (r.sameba     is int && r.sameba     >= 0))
        && (!('ikitakatta' in r) || (r.ikitakatta is int && r.ikitakatta >= 0))
        && (!('hozon' in r)      || (r.hozon      is int && r.hozon      >= 0));
    }
    /* 既存値 → 新値の差分が「ちょうど1つのキーで ±1」であることを検証。
       resource.data.reactions が存在しない場合は0と見なす。 */
    function rxVal(m, k) {
      return ('reactions' in m && m.reactions != null && k in m.reactions)
        ? m.reactions[k] : 0;
    }
    function reactionsDiffOk(oldD, newD) {
      return (
        (rxVal(newD, 'wakaru')     - rxVal(oldD, 'wakaru'))     >= -1
        && (rxVal(newD, 'wakaru')     - rxVal(oldD, 'wakaru'))     <= 1
        && (rxVal(newD, 'sameba')     - rxVal(oldD, 'sameba'))     >= -1
        && (rxVal(newD, 'sameba')     - rxVal(oldD, 'sameba'))     <= 1
        && (rxVal(newD, 'ikitakatta') - rxVal(oldD, 'ikitakatta')) >= -1
        && (rxVal(newD, 'ikitakatta') - rxVal(oldD, 'ikitakatta')) <= 1
        && (rxVal(newD, 'hozon')      - rxVal(oldD, 'hozon'))      >= -1
        && (rxVal(newD, 'hozon')      - rxVal(oldD, 'hozon'))      <= 1
        /* 合計絶対差分は 1 以下（1リクエスト=1リアクション分のみ） */
        && (
          abs(rxVal(newD, 'wakaru')     - rxVal(oldD, 'wakaru'))
          + abs(rxVal(newD, 'sameba')     - rxVal(oldD, 'sameba'))
          + abs(rxVal(newD, 'ikitakatta') - rxVal(oldD, 'ikitakatta'))
          + abs(rxVal(newD, 'hozon')      - rxVal(oldD, 'hozon'))
        ) <= 1
      );
    }
    /* Rules には abs() がないため自前実装。 */
    function abs(n) { return n >= 0 ? n : -n; }

    match /reports/{reportId} {
      /* 通報は作成のみ。閲覧は運営のみ。 */
      allow create: if request.auth != null
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.postId is string
        && request.resource.data.postId.size() <= 64
        && (request.resource.data.reason == null
            || (request.resource.data.reason is string
                && request.resource.data.reason.size() <= 500))
        && request.resource.data.createdAt == request.time;
      allow read: if isAdmin();
      /* 通報レコードの修正は禁止。削除のみ運営に許可（誤通報・スパムの整理用）。 */
      allow update: if false;
      allow delete: if isAdmin();
    }

    /* 上記以外のパスはすべて拒否 */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
