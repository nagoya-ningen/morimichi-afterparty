rules_version = '2';

/* 森道 After party — Cloud Storage セキュリティルール
   ・写真は posts/{postId}/photo.jpg に保存。
   ・read は公開（フィードで誰でも表示）。
   ・write は認証済みユーザーのみ。画像のみ・5MB以下に制限。
   ・delete はクライアント不可（運営がコンソールで対応）。
   ・App Check を有効にすると、これに加えてBotが弾かれる。 */

service firebase.storage {
  match /b/{bucket}/o {

    match /posts/{postId}/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow delete: if false;
    }

    /* 上記以外のパスはすべて拒否 */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
